#!/usr/bin/env python3
"""
Mock sbatch for testing the SlurmJobContainer backend.

Behaviour:
  - Parses --parsable and --nodelist from the command line (both ignored silently).
  - Reads #SBATCH --output=PATH and #SBATCH --error=PATH from the job script.
  - Executes the job script with bash, redirecting stdout/stderr to those paths.
  - Always prints "12345" as the job ID and exits 0 (submission always succeeds).
"""

import argparse
import os
import re
import subprocess
import sys

parser = argparse.ArgumentParser(add_help=False)
parser.add_argument("--parsable", action="store_true")
parser.add_argument("--nodelist", default=None)
parser.add_argument("script")
args = parser.parse_args()

output_path = None
error_path = None
with open(args.script) as f:
    for line in f:
        line = line.strip()
        m = re.match(r"#SBATCH --output=(.+)", line)
        if m:
            output_path = m.group(1)
        m = re.match(r"#SBATCH --error=(.+)", line)
        if m:
            error_path = m.group(1)

out_file = open(output_path, "w") if output_path else None
if error_path and error_path != output_path:
    err_file = open(error_path, "w")
else:
    # Interleaved mode: both streams go to the same file
    err_file = out_file

subprocess.run(
    ["bash", args.script],
    stdout=out_file,
    stderr=err_file,
    env={**os.environ, "SLURM_JOB_ID": "12345"},
)

if out_file is not None:
    out_file.close()
if err_file is not None and err_file is not out_file:
    err_file.close()

# Print a fixed job ID — the return value of sbatch --parsable
print("12345")
sys.exit(0)
